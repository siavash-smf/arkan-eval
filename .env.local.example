# ─────────────────────────────────────────────────────────────
# آرکان‌ایوال — نمونه‌ی متغیرهای محیطی
# این فایل را به .env.local کپی کنید و مقادیر واقعی را بگذارید.
# ─────────────────────────────────────────────────────────────

# ── ۱. مدل داور (الزامی) ─────────────────────────────────────
# داورِ هوش مصنوعی از OpenRouter استفاده می‌کند.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# مدلی که نقش «داور» را بازی می‌کند.
# قاعده‌ی مهم: داور باید از مدلِ تحت آزمون قوی‌تر یا هم‌سطح باشد.
JUDGE_MODEL=google/gemini-2.5-flash

# ── ۲. هدف ارزیابی (الزامی) ──────────────────────────────────
# آدرس چت‌باتی که می‌خواهیم بسنجیم.
TARGET_CHAT_URL=https://arkan-website-chatbot.vercel.app/api/chat

# ── ۳. ذخیره‌سازی نتایج (اختیاری) ─────────────────────────────
# اگر خالی بماند، نتایج در حافظه می‌ماند و با ری‌استارت پاک می‌شود.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── ۴. مانیتورینگ تولید (اختیاری) ────────────────────────────
# دیتابیس چت‌بات زنده‌ی آرکان — فقط خواندنی، برای بخش «تولید».
# اگر خالی بماند، آن بخش داشبورد پیام «تنظیم‌نشده» نشان می‌دهد.
ARKAN_SUPABASE_URL=
ARKAN_SUPABASE_SERVICE_ROLE_KEY=

# ── ۵. محافظت داشبورد (اختیاری) ──────────────────────────────
# اگر خالی بماند داشبورد کاملاً باز است. برای دیپلوی حتماً پرش کنید.
EVAL_PASSWORD=
